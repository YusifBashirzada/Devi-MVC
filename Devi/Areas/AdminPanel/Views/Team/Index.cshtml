@using Devi.Areas.AdminPanel.ViewModels
@model List<Employee>

@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Employee Table</h4>
                <div class="table-responsive">
                    <a asp-controller="team" asp-action="create" class="btn btn-outline-success btn-fw">Create</a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Id
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Position
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Employee employee in Model)
                            {
                                count++;
                                <tr>
                                    <td>
                                        <p>@count</p>
                                    </td>
                                    <td>
                                        <img src="~/assets/img/@employee.ImageUrl" />
                                    </td>
                                    <td>
                                        <p>@employee.Name</p>
                                    </td>
                                    <td>
                                        <p>@employee.Position.Name</p>
                                    </td>
                                    <td>
                                        <a asp-action="update" asp-route-id="@employee.Id" class="btn btn-outline-warning btn-fw">Edit</a>
                                        <a asp-action="delete" asp-route-id="@employee.Id" class="btn btn-outline-danger btn-fw">Delete</a>
                                        <a asp-action="Detail" asp-route-id="@employee.Id" class="btn btn-outline-info btn-fw">Detail</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



