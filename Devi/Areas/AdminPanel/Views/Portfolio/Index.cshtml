@using Devi.Areas.AdminPanel.ViewModels
@model List<Portfolio>

@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Portfolio Table</h4>
                <div class="table-responsive">
                    <a asp-controller="portfolio" asp-action="create" class="btn btn-outline-success btn-fw">Create</a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Category
                                </th>
                                <th>
                                    Description
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Portfolio portfolio in Model)
                            {
                                count++;
                                <tr>
                                    <td>
                                        <p>@count</p>
                                    </td>
                                    <td>
                                        <img src="~/assets/img/@portfolio.Image" />
                                    </td>
                                    <td>
                                        <p>@portfolio.Category</p>
                                    </td>
                                    <td>
                                        <p>@(portfolio.Description?.Length > 60 ? portfolio.Description.Substring(0, 60) + "..." : portfolio.Description)</p>
                                    </td>
                                    <td>
                                        <a asp-action="update" asp-route-id="@portfolio.Id" class="btn btn-outline-warning btn-fw">Edit</a>
                                        <a asp-action="delete" asp-route-id="@portfolio.Id" class="btn btn-outline-danger btn-fw">Delete</a>
                                        <a asp-action="Detail" asp-route-id="@portfolio.Id" class="btn btn-outline-info btn-fw">Detail</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


